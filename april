    <hr class="rule-mid">

    <div class="footer">
      <div class="footer-line1">Bring &nbsp;·&nbsp; Share &nbsp;·&nbsp; Discover</div>
      <div class="footer-handle">
        <span class="ornament">✦</span> @mkesoundclub <span class="ornament">✦</span>
      </div>
    </div>

  </div>

  <div class="torn-bottom"></div>

</div>
